# MySQL connection settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tripdeck

# Backend API endpoint (leave empty to use relative path via proxy)
# Example: http://192.168.1.100
VITE_API_DOMAIN=
VITE_API_PORT=3001

# OpenWeatherMap API key (primary weather source, supports up to 5 days ahead)
# Get a free key at https://openweathermap.org/api
VITE_OWM_API_KEY=

# Visual Crossing API key (extended weather source, supports up to 15 days ahead)
# Used as fallback when OWM is unavailable or the date exceeds OWM's 5-day range
# Get a free key at https://www.visualcrossing.com/weather-api
# Leave both keys empty to disable the weather feature
VITE_VC_API_KEY=

# Frontend port
FRONTEND_PORT=3000
