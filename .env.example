# MySQL connection settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tripdeck

# Backend API endpoint (leave empty to use relative path via proxy)
# Example: http://192.168.1.100
VITE_API_DOMAIN=
VITE_API_PORT=3001

# OpenWeatherMap API key (for day weather display in trip itinerary)
# Get a free key at https://openweathermap.org/api
# Leave empty to disable the weather feature
VITE_OWM_API_KEY=

# Frontend port
FRONTEND_PORT=3000
